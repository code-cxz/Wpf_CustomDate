<UserControl
    x:Class="nofun.control.CustomDate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:nofun.control"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:CustomDate}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Visibility="Collapsed">
        <Border
            x:Name="DateComponent"
            Padding="10,0,10,10"
            Background="#0C1E2B"
            BorderBrush="#2597AD"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.1*" />
                        <ColumnDefinition Width="0.8*" />
                        <ColumnDefinition Width="0.1*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="previousButton"
                        Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="LeftArrow_Click">
                        <Path
                            x:Name="LeftPrevious"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 5,0 L 5,10 L 0,5 Z"
                            Fill="#D3DEE2">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Border>

                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#8FE9EA"
                        MouseLeftButtonDown="CurrentYearMonth_Click"
                        Text="{Binding CurrentYearMonth}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <!--  情况一：当为 DayView 且 鼠标悬浮时  -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                            <Condition Binding="{Binding calendarViewMode}" Value="DayView" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Opacity" Value="0.5" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>

                                    <!--  情况二：当为 MonthView 且 鼠标悬浮时  -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                            <Condition Binding="{Binding calendarViewMode}" Value="MonthView" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Opacity" Value="0.5" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Border
                        Grid.Column="2"
                        Background="Transparent"
                        MouseLeftButtonDown="RightArrow_Click">
                        <Path
                            x:Name="RightNext"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 0,0 L 0,10 L 5,5 Z"
                            Fill="#D3DEE2">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Border>

                </Grid>

                <UniformGrid
                    x:Name="WeekList"
                    Grid.Row="1"
                    Margin="0,5"
                    Columns="7"
                    Rows="1">

                    <UniformGrid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Foreground" Value="#BFC9CD" />
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </UniformGrid.Resources>
                </UniformGrid>


                <UniformGrid
                    x:Name="DayList"
                    Grid.Row="2"
                    Columns="7"
                    Rows="6">

                    <UniformGrid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5,5" />
                            <Setter Property="Foreground" Value="#BFC9CD" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </UniformGrid.Resources>
                </UniformGrid>


                <UniformGrid
                    x:Name="MonthList"
                    Grid.Row="2"
                    Columns="4"
                    Rows="3">



                    <UniformGrid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5,10" />
                            <Setter Property="Foreground" Value="#BFC9CD" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </UniformGrid.Resources>
                </UniformGrid>

                <UniformGrid
                    x:Name="YearList"
                    Grid.Row="2"
                    Columns="4"
                    Rows="3">

                    <UniformGrid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5,10" />
                            <Setter Property="Foreground" Value="#BFC9CD" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </UniformGrid.Resources>
                </UniformGrid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
